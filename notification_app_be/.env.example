PORT=8080
EVALUATION_BASE_URL=http://4.224.186.213

# Copy this file to .env and fill real evaluator credentials there.
# Do not commit .env. The repository .gitignore already excludes it.

# Preferred for evaluation calls while the token is valid.
EVALUATION_ACCESS_TOKEN=<paste_access_token_here_without_spaces_or_line_breaks>

# Used to refresh the token when the server returns 401, or when no direct token is supplied.
EVALUATION_CLIENT_ID=<client_id_from_registration>
EVALUATION_CLIENT_SECRET=<client_secret_from_registration>
EVALUATION_EMAIL=<registered_email>
EVALUATION_NAME=<registered_name>
EVALUATION_ROLL_NO=22MIS1142
EVALUATION_MOBILE_NO=<registered_mobile_number>
EVALUATION_ACCESS_CODE=<access_code_from_evaluator>

NOTIFICATIONS_API_PATH=/evaluation-service/notifications
MARK_READ_API_PATH=/evaluation-service/notifications/:id/read

# Local development can keep this false so missing evaluator credentials do not break health checks.
# For final evaluator runs, set this to true in .env after credentials are verified.
LOG_REQUIRE_REMOTE=false
